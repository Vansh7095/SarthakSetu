# SarthakSetu — Development Environment Variables
#
# Copy this file to .env and fill in your values.
# Never commit .env files to version control.

# ---------------------------------------------------------------------------
# Node Environment
# ---------------------------------------------------------------------------
NODE_ENV=development

# ---------------------------------------------------------------------------
# Ports
# ---------------------------------------------------------------------------
# Backend API port (default: 8080)
PORT=8080

# Frontend Vite dev server port (default: 5173)
FRONTEND_PORT=5173

# ---------------------------------------------------------------------------
# Base Path
# ---------------------------------------------------------------------------
# The base URL path for the frontend SPA. Use "/" for local dev.
BASE_PATH=/

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Standard PostgreSQL connection string.
# Example for local PostgreSQL: postgres://user:password@localhost:5432/sarthaksetu
# Example for Docker: postgres://sarthaksetu:changeme@localhost:5432/sarthaksetu
DATABASE_URL=postgres://user:password@localhost:5432/sarthaksetu

# ---------------------------------------------------------------------------
# Clerk Authentication
# ---------------------------------------------------------------------------
# Get these from https://dashboard.clerk.com after creating an application.
# Use "Development" instance keys for local development.
#
# Frontend publishable key (starts with pk_test_ or pk_live_)
CLERK_PUBLISHABLE_KEY=pk_test_your_key_here

# Backend secret key (starts with sk_test_ or sk_live_)
CLERK_SECRET_KEY=sk_test_your_key_here

# Vite-specific frontend key (same as CLERK_PUBLISHABLE_KEY)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here

# Optional: Clerk proxy URL for custom domains.
# Leave empty for local development.
VITE_CLERK_PROXY_URL=

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
# Log level: trace, debug, info, warn, error, fatal
LOG_LEVEL=info
