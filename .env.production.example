# SarthakSetu — Production Environment Variables
#
# Copy this file to .env.production (or use your secrets manager)
# and fill in your production values.
# Never commit production secrets to version control.

# ---------------------------------------------------------------------------
# Node Environment
# ---------------------------------------------------------------------------
NODE_ENV=production

# ---------------------------------------------------------------------------
# Ports
# ---------------------------------------------------------------------------
# Backend API port (usually 8080, proxied by nginx)
PORT=8080

# Frontend Vite preview / static serve port (if not using nginx)
FRONTEND_PORT=5173

# ---------------------------------------------------------------------------
# Base Path
# ---------------------------------------------------------------------------
BASE_PATH=/

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Production PostgreSQL connection string.
# Use a strong password. Enable SSL in production.
DATABASE_URL=postgres://sarthaksetu:strong_password@postgres:5432/sarthaksetu

# ---------------------------------------------------------------------------
# Clerk Authentication
# ---------------------------------------------------------------------------
# Use "Production" instance keys from Clerk Dashboard.
# Switch to live keys before going public.
#
# Frontend publishable key (starts with pk_live_)
CLERK_PUBLISHABLE_KEY=pk_live_your_key_here

# Backend secret key (starts with sk_live_)
CLERK_SECRET_KEY=sk_live_your_key_here

# Vite-specific frontend key (same as CLERK_PUBLISHABLE_KEY)
VITE_CLERK_PUBLISHABLE_KEY=pk_live_your_key_here

# Clerk proxy URL — set this to your domain + /api/__clerk
# Example: https://sarthaksetu.org/api/__clerk
VITE_CLERK_PROXY_URL=

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL=info

# ---------------------------------------------------------------------------
# Optional: Error Tracking (Sentry)
# ---------------------------------------------------------------------------
# SENTRY_DSN=https://your_dsn@sentry.io/project
